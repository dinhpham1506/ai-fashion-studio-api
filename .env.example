# Copy to .env at repo root:  cp .env.example .env
# docker-compose (root) reads .env for infra + backends.
#
# ⚠️ FILE NÀY ĐƯỢC COMMIT (public). KHÔNG điền secret thật vào đây.
#    Giá trị dưới đây là placeholder; secret thật (DB, MinIO, PayOS, JWT...) chỉ điền vào .env.
#    .env đã được .gitignore → không bao giờ bị đẩy lên repo.

# --- Postgres (1 DB chung, 18 bảng / 8 schema) ---
POSTGRES_DB=ai_fashion_studio_db
POSTGRES_USER=aifashionstudio
POSTGRES_PASSWORD=change_me_postgres_password
POSTGRES_PORT=15432

# --- pgAdmin ---
PGADMIN_EMAIL=admin@aifashionstudio.local
PGADMIN_PASSWORD=change_me_pgadmin_password
PGADMIN_PORT=15050

# --- Kafka ---
KAFKA_INTERNAL_PORT=9092
KAFKA_EXTERNAL_PORT=39092
KAFKA_UI_PORT=18085
KAFKA_IMAGE=apache/kafka:3.7.0

# --- MinIO (object storage: images, prints, tryon, invoices) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio_password
MINIO_API_PORT=19000
MINIO_CONSOLE_PORT=19001

# --- Services (FE gọi vào api-gateway) ---
GATEWAY_PORT=8080
JAVA_API_PORT=8081
DOTNET_API_PORT=8082

# --- PayOS / SePay (payment thật) - điền giá trị sandbox của bạn ---
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
