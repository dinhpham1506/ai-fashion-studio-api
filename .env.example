# Copy to .env at repo root:  cp .env.example .env
# docker-compose (root) reads .env for infra + backends.
#
# ⚠️ FILE NÀY ĐƯỢC COMMIT (public). KHÔNG điền secret thật vào đây.
#    Giá trị dưới đây là DEFAULT local an toàn; secret thật (PayOS, JWT...) chỉ điền vào .env.
#    .env đã được .gitignore → không bao giờ bị đẩy lên repo.

# --- Postgres (1 DB chung, 18 bảng / 8 schema) ---
POSTGRES_DB=ai_tshirt_mvp_db
POSTGRES_USER=aishop
POSTGRES_PASSWORD=aishop_password
POSTGRES_PORT=5432

# --- pgAdmin ---
PGADMIN_EMAIL=admin@aishop.local
PGADMIN_PASSWORD=admin123
PGADMIN_PORT=5050

# --- Kafka ---
KAFKA_INTERNAL_PORT=9092
KAFKA_EXTERNAL_PORT=29092
KAFKA_UI_PORT=8085

# --- MinIO (object storage: images, prints, tryon, invoices) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- Services (FE gọi vào api-gateway) ---
GATEWAY_PORT=8080
JAVA_API_PORT=8081
DOTNET_API_PORT=8082

# --- PayOS / SePay (payment thật) - điền giá trị sandbox của bạn ---
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
